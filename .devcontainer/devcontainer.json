{
  "name": "wavystack-devenv",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "."
  },
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "features": {
    "ghcr.io/shyim/devcontainers-features/bun:0": {
      "version": "1.1.0"
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    },
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.12"
    },
    "ghcr.io/devcontainers/features/java:1": {
      "version": "17"
    },
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },
  "forwardPorts": [3000, 3001, 5173, 8080, 8081, 8084, 19000, 19001, 19002],
  "portsAttributes": {
    "3000": {
      "label": "Web App",
      "onAutoForward": "openBrowser"
    },
    "3001": {
      "label": "Alt Web App"
    },
    "5173": {
      "label": "Vite App",
      "onAutoForward": "openBrowser"
    },
    "8080": {
      "label": "API"
    },
    "8081": {
      "label": "Admin / Secondary API"
    },
    "8084": {
      "label": "Processor API"
    },
    "19000": {
      "label": "Expo Dev Server"
    },
    "19001": {
      "label": "Expo Metro / LAN"
    },
    "19002": {
      "label": "Expo Dev Tools"
    }
  },
  "containerEnv": {
    "CHOKIDAR_USEPOLLING": "true",
    "WATCHPACK_POLLING": "true",
    "EXPO_NO_TELEMETRY": "1",
    "BROWSER": "none"
  },
  "customizations": {
    "vscode": {
      "settings": {
        "github.copilot.nextEditSuggestions.enabled": true,
        "workbench.iconTheme": "Monokai Pro (Filter Machine) Icons",
        "workbench.colorTheme": "Bearded Theme Anthracite",
        "editor.formatOnPaste": true,
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.minimap.enabled": false,
        "editor.fontLigatures": true,
        "editor.fontFamily": "CaskaydiaCove Nerd Font Mono, CaskaydiaCove Nerd Font, monospace, Fira Code, Consolas, 'Courier New', monospace",
        "editor.fontWeight": "400",
        "editor.fontSize": 10,
        "editor.lineHeight": 2.5,
        "terminal.integrated.fontSize": 11,
        "terminal.integrated.lineHeight": 1.7,
        "terminal.integrated.fontFamily": "CaskaydiaCove Nerd Font Mono, CaskaydiaCove Nerd Font, monospace",
        "terminal.integrated.fontLigatures.enabled": true,
        "terminal.integrated.fontWeight": "400",
        "terminal.integrated.gpuAcceleration": "on",
        "files.watcherExclude": {
          "**/.git/objects/**": true,
          "**/.git/subtree-cache/**": true,
          "**/node_modules/**": true,
          "**/.next/**": true,
          "**/dist/**": true,
          "**/build/**": true,
          "**/.expo/**": true,
          "**/android/app/build/**": true,
          "**/ios/build/**": true,
          "**/target/**": true
        }
      },
      "extensions": [
        "ms-azuretools.vscode-containers",
        "oven.bun-vscode",
        "BeardedBear.beardedtheme",
        "BeardedBear.beardedicons",
        "miguelsolorio.symbols",
        "WallabyJs.console-ninja",
        "aaron-bond.better-comments",
        "naumovs.color-highlight",
        "mikestead.dotenv",
        "pomdtr.excalidraw-editor",
        "bradlc.vscode-tailwindcss",
        "oouo-diogo-perdigao.docthis",
        "esbenp.prettier-vscode",
        "EraserLabs.eraserlabs",
        "dsznajder.es7-react-js-snippets",
        "monokai.theme-monokai-pro-vscode",
        "whizkydee.material-palenight-theme",
        "donjayamanne.python-extension-pack",
        "enkia.tokyo-night",
        "bmewburn.vscode-intelephense-client",
        "humao.rest-client",
        "ms-vscode.vscode-typescript-next",
        "msjsdiag.vscode-react-native",
        "expo.vscode-expo-tools",
        "rust-lang.rust-analyzer",
        "tamasfe.even-better-toml",
        "tauri-apps.tauri-vscode",
        "ms-vscode.cpptools",
        "waderyan.gitblame",
        "usernamehw.errorlens",
        "MS-vsliveshare.vsliveshare",
        "pranaygp.vscode-css-peek",
        "wix.vscode-import-cost",
        "rangav.vscode-thunder-client",
        "formulahendry.docker-extension-pack",
        "christian-kohler.path-intellisense",
        "Gruntfuggly.todo-tree"
      ]
    }
  },
  "remoteEnv": {
    "SSH_AUTH_SOCK": "/ssh-agent"
  },
  "mounts": [],
  "postCreateCommand": "bash .devcontainer/installations.sh",
  "remoteUser": "vscode"
}
